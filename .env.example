# [FastAPI 연결 설정]
DATABASE_URL=postgresql+asyncpg://msh:your_password_here@localhost:5432/rpg_db

# [Redis 설정]
REDIS_URL=redis://localhost:6379/0

# [보안 설정]
SECRET_KEY=your_generate_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# [DB 세팅]
POSTGRES_USER=msh
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=rpg_db