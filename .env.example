# [DB 세팅] - Docker 및 DB 접속 기본 정보
POSTGRES_USER=msh
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=rpg_db

# [FastAPI 연결 설정] - 비동기 드라이버(asyncpg) 사용
# 실제 사용 시: postgresql+asyncpg://msh:비밀번호@localhost:5432/rpg_db
DATABASE_URL=postgresql+asyncpg://msh:your_password_here@localhost:5432/rpg_db

# [Redis 설정] - 캐시 및 세션 관리용
REDIS_URL=redis://localhost:6379/0

# [보안 설정]
# 토큰 서명에 사용할 비밀키 (실제 값은 절대 깃허브에 올리지 마세요)
# 생성 방법: openssl rand -hex 32
SECRET_KEY=your_generate_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30